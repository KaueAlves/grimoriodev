<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Backgrounds -->
    <Color x:Key="BackgroundPrimaryColor">#1E1E2E</Color>
    <Color x:Key="BackgroundSecondaryColor">#2A2A3C</Color>
    <Color x:Key="BackgroundTertiaryColor">#363650</Color>

    <!-- Foregrounds -->
    <Color x:Key="ForegroundPrimaryColor">#E0E0E0</Color>
    <Color x:Key="ForegroundSecondaryColor">#A0A0B0</Color>
    <Color x:Key="ForegroundAccentColor">#7C3AED</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BackgroundPrimary" Color="{StaticResource BackgroundPrimaryColor}" />
    <SolidColorBrush x:Key="BackgroundSecondary" Color="{StaticResource BackgroundSecondaryColor}" />
    <SolidColorBrush x:Key="BackgroundTertiary" Color="{StaticResource BackgroundTertiaryColor}" />
    <SolidColorBrush x:Key="ForegroundPrimary" Color="{StaticResource ForegroundPrimaryColor}" />
    <SolidColorBrush x:Key="ForegroundSecondary" Color="{StaticResource ForegroundSecondaryColor}" />
    <SolidColorBrush x:Key="ForegroundAccent" Color="{StaticResource ForegroundAccentColor}" />

</ResourceDictionary>

<Window x:Class="GrimorioDev.Presentation.Views.StartScreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GrimórioDev"
        Height="680" Width="960"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanMinimize"
        TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <Style x:Key="CardHoverButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Opacity" Value="0.4"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1"/>
                    <Setter Property="Background" Value="#40FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ForegroundAccent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#6D28D9"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#5B21B6"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{StaticResource BackgroundTertiary}"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundPrimary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#404060"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#303050"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BackgroundTertiary}"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundPrimary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#40FFFFFF"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="{StaticResource ForegroundAccent}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="PART_ContentHost" Property="Margin" Value="8,6"/>
                                <Setter Property="BorderBrush" Value="{StaticResource ForegroundAccent}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#80FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BackgroundPrimary}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ════════════════════ HEADER ════════════════════ -->
            <Border Grid.Row="0" Padding="0" Background="{StaticResource BackgroundSecondary}"
                    BorderBrush="#40FFFFFF" BorderThickness="0,0,0,1">
                <Grid Height="120">
                    <Rectangle Opacity="0.08">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="{StaticResource ForegroundAccentColor}" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="⚜ GrimórioDev"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource ForegroundAccent}"
                                   HorizontalAlignment="Center"
                                   />
                        <TextBlock Text="Canvas infinito para desenvolvimento de software"
                                   FontSize="13"
                                   Foreground="{StaticResource ForegroundSecondary}"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ════════════════════ CONTENT ════════════════════ -->
            <Grid Grid.Row="1" Margin="28,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="300"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: Recent Workspaces -->
                <Border Grid.Column="0" CornerRadius="10"
                        Background="{StaticResource BackgroundSecondary}" Padding="0"
                        Margin="0,0,16,0"
                        BorderBrush="#20FFFFFF" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- List Header -->
                        <Border Grid.Row="0" Padding="20,16,20,12"
                                BorderBrush="#20FFFFFF" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="🖥  Workspaces Recentes"
                                           FontSize="15" FontWeight="SemiBold"
                                           Foreground="{StaticResource ForegroundPrimary}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding StatusMessage}"
                                           Foreground="{StaticResource ForegroundSecondary}"
                                           FontSize="11" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Loading -->
                        <Border Grid.Row="1" Background="{StaticResource BackgroundSecondary}"
                                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="⏳" FontSize="28" HorizontalAlignment="Center"/>
                                <TextBlock Text="Carregando..."
                                           Foreground="{StaticResource ForegroundSecondary}"
                                           FontSize="13" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Empty State -->
                        <Border Grid.Row="1"
                                Visibility="{Binding RecentWorkspaces.Count, Converter={StaticResource ZeroToVisibilityConverter}}"
                                Background="{StaticResource BackgroundSecondary}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="32">
                                <TextBlock Text="📂" FontSize="48" HorizontalAlignment="Center"/>
                                <TextBlock Text="Nenhum workspace ainda"
                                           Foreground="{StaticResource ForegroundSecondary}"
                                           FontSize="16" HorizontalAlignment="Center"
                                           Margin="0,12,0,4"/>
                                <TextBlock Text="Crie um novo workspace ao lado para começar"
                                           Foreground="{StaticResource ForegroundSecondary}"
                                           FontSize="12" HorizontalAlignment="Center" Opacity="0.7"/>
                            </StackPanel>
                        </Border>

                        <!-- Workspace List -->
                        <ScrollViewer Grid.Row="1" Visibility="{Binding IsBusy, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                      VerticalScrollBarVisibility="Auto" BorderThickness="0" Padding="12,8">
                            <ItemsControl ItemsSource="{Binding RecentWorkspaces}" BorderThickness="0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,4" Padding="0" CornerRadius="8"
                                                Background="{StaticResource BackgroundTertiary}"
                                                BorderBrush="Transparent" BorderThickness="1"
                                                Cursor="Hand">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource BackgroundTertiary}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}" Value="True">
                                                            <Setter Property="BorderBrush" Value="{StaticResource ForegroundAccent}"/>
                                                            <Setter Property="Background" Value="#2A2A50"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Border.InputBindings>
                                                <MouseBinding Gesture="LeftDoubleClick"
                                                              Command="{Binding DataContext.OpenWorkspaceCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                              CommandParameter="{Binding}"/>
                                            </Border.InputBindings>
                                            <Grid Margin="14,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Icon -->
                                                <Border Grid.Column="0" Width="40" Height="40"
                                                        CornerRadius="8"
                                                        Background="{StaticResource BackgroundSecondary}"
                                                        VerticalAlignment="Center" Margin="0,0,12,0">
                                                    <TextBlock Text="📦" FontSize="18"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>

                                                <!-- Info -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontWeight="SemiBold" FontSize="14"
                                                               Foreground="{StaticResource ForegroundPrimary}"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                        <TextBlock Foreground="{StaticResource ForegroundSecondary}" FontSize="11">
                                                            <Run Text="{Binding CardCount}"/><Run Text=" cards"/>
                                                        </TextBlock>
                                                        <TextBlock Text=" · " Foreground="{StaticResource ForegroundSecondary}" FontSize="11" Margin="4,0"/>
                                                        <TextBlock Foreground="{StaticResource ForegroundSecondary}" FontSize="11"
                                                                   Text="{Binding LastOpenedAt, StringFormat=\{0:dd/MM/yyyy\}}"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <!-- Action buttons -->
                                                <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                            VerticalAlignment="Center">
                                                    <Button Command="{Binding DataContext.OpenWorkspaceCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource CardHoverButton}"
                                                            ToolTip="Abrir workspace">
                                                        <TextBlock Text="▶" FontSize="16"/>
                                                    </Button>
                                                    <Button Command="{Binding DataContext.DeleteWorkspaceCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource CardHoverButton}"
                                                            ToolTip="Excluir workspace">
                                                        <TextBlock Text="🗑" FontSize="14"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Bottom bar -->
                        <Border Grid.Row="2" Padding="16,10"
                                BorderBrush="#20FFFFFF" BorderThickness="0,1,0,0">
                            <TextBlock Text="{Binding StatusMessage, FallbackValue='Pronto'}"
                                       Foreground="{StaticResource ForegroundSecondary}"
                                       FontSize="11"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- RIGHT: Actions Panel -->
                <StackPanel Grid.Column="1" VerticalAlignment="Top" Width="260">

                    <!-- Create Workspace -->
                    <Border CornerRadius="10" Background="{StaticResource BackgroundSecondary}"
                            Padding="0" Margin="0,0,0,12"
                            BorderBrush="#20FFFFFF" BorderThickness="1">
                        <StackPanel Margin="18,16">
                            <TextBlock Text="✨ Novo Workspace"
                                       FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource ForegroundPrimary}"
                                       Margin="0,0,0,14"/>

                            <TextBlock Text="Nome"
                                       Foreground="{StaticResource ForegroundSecondary}"
                                       FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding NewWorkspaceName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}" Margin="0,0,0,10"/>

                            <TextBlock Text="Descrição"
                                       Foreground="{StaticResource ForegroundSecondary}"
                                       FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding NewWorkspaceDescription, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}" Margin="0,0,0,10"/>

                            <TextBlock Text="Localização (opcional)"
                                       Foreground="{StaticResource ForegroundSecondary}"
                                       FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding NewWorkspaceLocation, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}" Margin="0,0,0,14"/>

                            <Button Content="➕ Criar Workspace"
                                    Command="{Binding CreateWorkspaceCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>

                    <!-- Quick Actions -->
                    <Border CornerRadius="10" Background="{StaticResource BackgroundSecondary}"
                            Padding="0"
                            BorderBrush="#20FFFFFF" BorderThickness="1">
                        <StackPanel Margin="18,16">
                            <TextBlock Text="⚡ Ações"
                                       FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource ForegroundPrimary}"
                                       Margin="0,0,0,12"/>

                            <Button Content="▶ Abrir Selecionado"
                                    Command="{Binding OpenWorkspaceCommand}"
                                    CommandParameter="{Binding SelectedWorkspace}"
                                    Style="{StaticResource SecondaryButton}"
                                    HorizontalAlignment="Stretch" Margin="0,0,0,8"/>

                            <Button Content="📁 Procurar Pasta..."
                                    Command="{Binding BrowseWorkspaceCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- ════════════════════ FOOTER ════════════════════ -->
            <Border Grid.Row="2" Padding="16,8"
                    Background="{StaticResource BackgroundSecondary}"
                    BorderBrush="#20FFFFFF" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="© 2026 GrimórioDev"
                               Foreground="{StaticResource ForegroundSecondary}"
                               FontSize="11"/>
                    <TextBlock Grid.Column="1" Text="v0.2.0 — Canvas Infinito"
                               Foreground="{StaticResource ForegroundSecondary}"
                               FontSize="11"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
